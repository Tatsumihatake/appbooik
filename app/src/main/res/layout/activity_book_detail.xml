<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Cover Buku Besar -->
        <ImageView
            android:id="@+id/ivDetailCover"
            android:layout_width="200dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp"/>

        <!-- Judul Buku -->
        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textAlignment="center"
            android:layout_marginBottom="8dp"/>

        <!-- Penulis Buku -->
        <TextView
            android:id="@+id/tvDetailAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#757575"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"/>

        <!-- Deskripsi/Sinopsis (Sementara Statis) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sinopsis"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDetailSynopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:textColor="#424242"
            android:text="Data sinopsis tidak selalu tersedia dari Open Library API untuk setiap buku. Ini adalah deskripsi contoh."
            android:layout_marginBottom="32dp"/>

        <!-- Tombol Mulai Membaca -->
        <Button
            android:id="@+id/btnStartReading"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Mulai Membaca"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#6200EE"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>